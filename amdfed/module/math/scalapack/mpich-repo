#%Module1.0#####################################################################
set docstr  "ScaLAPACK, compiled with MPICH. Both from Fedora DNF repository"

proc ModulesHelp { } {
        global dotversion
        puts stderr $docstr
}

module-whatis       $docstr

conflict        scalapack/openmpi-repo
module load     mpich/repo

prepend-path    CPATH                /usr/include/blacs
prepend-path    CMAKE_PREFIX_PATH    /usr/lib64/cmake/scalapack-2.2.2
